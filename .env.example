# ═══════════════════════════════════════════════════════
# Cloud Kitchen — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env files to git
# ═══════════════════════════════════════════════════════

# ── PostgreSQL (Docker Compose) ──
POSTGRES_USER=kitchen
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=kitchen_db
DATABASE_URL=postgres://kitchen:CHANGE_ME_STRONG_PASSWORD@localhost:5432/kitchen_db

# ── Redis (Docker Compose) ──
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# ── Grafana ──
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GRAFANA_ROOT_URL=http://localhost:3003

# ── JWT Auth ──
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_64_CHARS_PLUS
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_SECRET_64_CHARS

# ── App ──
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
APP_URL=http://localhost:3000

# ── Stripe ──
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Delivery Aggregator ──
# Sign up at ShipRocket/Rapido/Zomato Fleet
DISPATCH_API_KEY=CHANGE_ME
DISPATCH_API_URL=https://api.delivery-partner.com/v1

# ── SendGrid (email) ──
# Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.CHANGE_ME
SENDGRID_FROM_EMAIL=orders@your-kitchen.com
ALERT_EMAIL_TO=admin@your-kitchen.com

# ── Twilio (SMS) ──
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1234567890

# ── Slack / Telegram (admin alerts) ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME

# ── Supabase (real-time + auth) ──
# Get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
#
# NEXT_PUBLIC_SUPABASE_ANON_KEY = Public anon key (safe for browser, role=anon)
# SUPABASE_SERVICE_ROLE_KEY     = Secret service_role key (NEVER expose to client, role=service_role)
# These are DIFFERENT keys — do NOT use the service_role key as the anon key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME_ANON_KEY
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=CHANGE_ME_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=CHANGE_ME

# ── NextAuth ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET

# ── Google OAuth ──
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── AI Features (optional — skip if not using Groq/Gemini) ──
# Groq: https://console.groq.com/keys (for real-time recs + promo suggestions)
GROQ_API_KEY=gsk_CHANGE_ME
# Gemini: https://aistudio.google.com/apikey (for feedback sentiment analysis)
GEMINI_API_KEY=AIza_CHANGE_ME

# ── Dev Bypass (OPTIONAL — development only) ──
# When true, allows bypassing OTP with phone +919876543210 and OTP 2563
# NEVER set to true in production
ENABLE_DEV_BYPASS=false

# ── Backup ──
BACKUP_DIR=./backups
