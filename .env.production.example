# ═══════════════════════════════════════════════════════
# Free Deployment — Environment Variables Template
# Copy these to your hosting platform (Vercel / Render)
# ═══════════════════════════════════════════════════════

# ── Supabase (Free PostgreSQL) ──
# Get from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Upstash (Free Redis) ──
# Get from: https://upstash.com/console → Your database → Connection details
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT:6379

# ── Database URL (from Supabase) ──
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))") ──
JWT_SECRET=your-generated-jwt-secret
JWT_REFRESH_SECRET=your-generated-jwt-refresh-secret

# ── App URLs (update after deployment) ──
APP_URL=https://your-web.vercel.app
CORS_ORIGINS=https://your-web.vercel.app,https://your-admin.vercel.app

# ── Stripe (Optional — for payments) ──
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ── SendGrid (Optional — for email) ──
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=orders@thekatanguriskitchen.com

# ── Twilio (Optional — for SMS) ──
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1xxx

# ── AI (Optional — for recommendations) ──
GROQ_API_KEY=gsk_xxx
GEMINI_API_KEY=AIza_xxx

# ── Security ──
NODE_ENV=production
ENABLE_DEV_BYPASS=false
LOG_LEVEL=info
