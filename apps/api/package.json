    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.4",
    "prom-client": "^15.1.3",
    "stripe": "^14.20.0",
    "tsx": "^4.7.1",
    "twilio": "^6.0.2",
    "zod": "^3.22.4"
