# ═══════════════════════════════════════════════════════════
# The Katanguri's Kitchen — API Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env files to git
# ═══════════════════════════════════════════════════════════

# ── Server ──
NODE_ENV=production
PORT=3001

# ── Database (REQUIRED) ──
POSTGRES_USER=kitchen
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=kitchen_db
DATABASE_URL=postgres://kitchen:change-me-to-a-strong-password@localhost:5432/kitchen_db

# ── Redis (REQUIRED) ──
REDIS_PASSWORD=change-me-to-a-strong-redis-password
REDIS_URL=redis://:change-me-to-a-strong-redis-password@localhost:6379

# ── Auth (REQUIRED) ──
JWT_SECRET=change-me-to-a-strong-random-secret-64-chars
JWT_REFRESH_SECRET=change-me-to-another-strong-random-secret-64-chars

# ── Supabase (REQUIRED for auth + realtime) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── CORS ──
CORS_ORIGINS=https://thekatanguriskitchen.com,https://admin.thekatanguriskitchen.com

# ── Stripe (OPTIONAL) ──
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Twilio — SMS/OTP ──
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Resend — Email ──
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=orders@your-kitchen.com
APP_URL=https://thekatanguriskitchen.com

# ── AI ──
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key

# ── Alerts ──
ALERT_EMAIL_TO=admin@your-kitchen.com

# ── Dev Bypass (OPTIONAL — development only) ──
# When true, allows bypassing OTP with phone +919876543210 and OTP 2563
# NEVER set to true in production
ENABLE_DEV_BYPASS=false

# ── Backup ──
BACKUP_DIR=./backups
